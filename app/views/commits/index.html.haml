- content_for :title, "Commits on #{@branch.name}"
- visible_count    = @commits.length
- newer_disabled   = @newer_href.nil?
- older_disabled   = @older_href.nil?
- newer_href       = @newer_href
- older_href       = @older_href
- # When no explicit before= was passed, the cursor is "now" — surface
- # that to the user as "latest" rather than rendering today's actual time,
- # which feels arbitrary.
- displayed_time   = @before_time.in_time_zone(time_zone)

.space-y-6
  -# Headline: branch chip + date chip + muted time + summary line.
  %header.flex.flex-col.gap-2
    .flex.flex-wrap.items-baseline.gap-x-3.gap-y-2
      %h1.text-2xl.font-semibold.tracking-tight.text-fg Commits on
      - picker_sections = [{ label: "Recently updated", branches: @recent_branches }, { label: "Older", branches: @older_branches }]
      = render "branch_picker", branch: @branch, sections: picker_sections, link_for: ->(b) { commits_path(branch: b.name) }
      %span.text-2xl.font-semibold.tracking-tight.text-fg.whitespace-nowrap on or before
      = render "date_picker", selected_time: displayed_time, branch: @branch
      %span.font-mono.text-fg-subtle.tabular-nums{ class: "text-[12px]" }
        = displayed_time.strftime("%-l:%M %P %Z")

    %p.text-xs.text-fg-muted
      = "#{number_with_delimiter(@max_num)} commits on this branch"
      %span.mx-1 ·
      = "#{visible_count} shown"
      - if @last_activity_at
        %span.mx-1 ·
        = "newest in view #{short_relative_time(@last_activity_at)}"

  -# Subway map fills the top strip. The partial accepts the whole
  -# page worth of commits and pans a fixed window through them.
  = render "subway_map", commits: @commits, commit_states: @commit_states

  -# Table card. The toolbar row (search input + Newer/Older
  -# buttons) lived here previously but moved into the subway map
  -# itself — its pan arrows double as page-navigation buttons
  -# when at the far end of a page. The search box is also hidden
  -# until it's actually wired to client-side filtering; restoring
  -# it should be a single block insert here.
  .rounded-lg.border.border-border.bg-bg-elev{ style: "box-shadow: var(--shadow-card-sm);" }
    -# Table header — hidden on narrow viewports where the table layout
    -# breaks down and the mobile card layout below takes over.
    .hidden.gap-3.border-b.border-border-subtle.bg-bg-subtle.px-4.py-2.font-semibold.uppercase.tracking-wide.text-fg-subtle{ class: "text-[10px] sm:grid grid-cols-[12px_minmax(0,2.4fr)_minmax(0,1.4fr)_minmax(0,1.4fr)_minmax(0,1.6fr)_minmax(0,1.4fr)_minmax(0,1fr)_minmax(0,0.8fr)]" }
      %span &nbsp;
      %span Commit
      %span SHA
      %span Author
      %span Build
      %span Tests
      %span Flags
      %span.text-right When

    -# Rows, grouped by age relative to the active cursor.
    - if @commits.empty?
      .px-4.py-10.text-center.text-sm.text-fg-muted
        No commits on this branch on or before the selected date.
    - else
      - group_commits_by_age(@commits, now: displayed_time).each do |bucket_id, bucket_label, bucket_commits|
        .border-b.border-border-subtle.bg-bg-subtle.px-4.py-1.flex.items-center.justify-between
          %span.font-semibold.uppercase.tracking-wide.text-fg-subtle{ class: "text-[10px]" }= bucket_label
          %span.text-fg-subtle.tabular-nums{ class: "text-[10px]" }= bucket_commits.size
        - bucket_commits.each do |commit|
          - state = @commit_states[commit.id]
          - flag_count = state[:flags][:fpe].to_i + state[:flags][:checksum].to_i + state[:flags][:inlists_full].to_i

          -# Mobile row (< sm). The 8-column desktop grid below has no
          -# chance of fitting status pills + author + flags in a 343px
          -# content area, so on mobile we stack the same information
          -# in three lines: message, identity meta (sha · author · age
          -# · optional PR + test count), then status pills wrapping
          -# freely. Both rows are rendered; Tailwind's display:none
          -# pulls the non-matching one out of the accessibility tree.
          = link_to commit_path(branch: @branch.name, sha: commit.short_sha),
                   class: "flex sm:hidden items-start gap-3 border-b border-border-subtle px-4 py-3 text-sm text-fg no-underline hover:bg-bg-subtle" do
            %span.inline-block.h-2.w-2.rounded-full.shrink-0{ class: status_dot_class(state), style: "margin-top: 6px;", title: "build #{state[:build][:status]} · tests #{state[:tests][:status]}" }
            .min-w-0.flex-1.flex.flex-col.gap-1.5
              %span.font-medium.text-fg{ class: "line-clamp-2" }= commit.message_first_line(120)
              .flex.flex-wrap.items-center.gap-x-2.gap-y-0.5.text-fg-muted{ class: "text-[11px]" }
                %span.font-mono.text-brand= commit.short_sha
                %span.text-fg-subtle ·
                .inline-flex.items-center.gap-1.min-w-0
                  = commit_avatar(commit.author, size: 14)
                  %span.truncate= commit.author
                %span.text-fg-subtle ·
                %span.tabular-nums= short_relative_time(commit.commit_time, now: displayed_time)
                - if commit.respond_to?(:pr_number) && commit.pr_number
                  %span.text-fg-subtle ·
                  %span= "##{commit.pr_number}"
                - if commit.test_case_count.to_i > 0
                  %span.text-fg-subtle ·
                  %span= "#{commit.test_case_count} tests"
              .flex.flex-wrap.items-center.gap-1.5
                = build_status_pill(state, size: :sm)
                = test_status_pill(state, size: :sm)
                - if flag_count > 0
                  = flag_chips(state)

          -# Desktop row (≥ sm). Original 8-column grid layout, unchanged.
          = link_to commit_path(branch: @branch.name, sha: commit.short_sha),
                   class: "hidden sm:grid gap-3 border-b border-border-subtle px-4 py-3 text-sm text-fg no-underline hover:bg-bg-subtle items-center grid-cols-[12px_minmax(0,2.4fr)_minmax(0,1.4fr)_minmax(0,1.4fr)_minmax(0,1.6fr)_minmax(0,1.4fr)_minmax(0,1fr)_minmax(0,0.8fr)]" do
            %span.inline-block.h-2.w-2.rounded-full{ class: status_dot_class(state), title: "build #{state[:build][:status]} · tests #{state[:tests][:status]}" }
            .min-w-0.flex.flex-col.gap-0.5
              %span.truncate.font-medium.text-fg= commit.message_first_line(80)
              %span.text-fg-subtle{ class: "text-[11px]" }
                - meta_parts = []
                - meta_parts << "##{commit.pr_number}" if commit.respond_to?(:pr_number) && commit.pr_number
                - meta_parts << "#{commit.test_case_count} test cases" if commit.test_case_count.to_i > 0
                = meta_parts.join(" · ").presence || pluralize(commit.computer_count.to_i, "computer")
            %span.font-mono.text-brand.truncate{ class: "text-[12px]" }= commit.short_sha
            .flex.items-center.gap-2.min-w-0
              = commit_avatar(commit.author)
              %span.truncate.text-fg-muted{ class: "text-[12px]" }= commit.author
            .min-w-0= build_status_pill(state, size: :sm)
            .min-w-0= test_status_pill(state, size: :sm)
            .flex.flex-wrap.items-center.gap-1.min-w-0= flag_chips(state)
            %span.text-right.text-fg-subtle.tabular-nums{ class: "text-[11px]" }= short_relative_time(commit.commit_time, now: displayed_time)

  -# Bottom pagination mirror for long pages.
  .flex.items-center.justify-end.gap-2.text-xs
    = link_to "← Newer", (newer_href || commits_path(branch: @branch.name)),
                          class: "mesa-btn #{'pointer-events-none opacity-50' if newer_disabled}",
                          aria: { disabled: newer_disabled }
    = link_to "Older →", (older_href || "#"),
                          class: "mesa-btn #{'pointer-events-none opacity-50' if older_disabled}",
                          aria: { disabled: older_disabled }
