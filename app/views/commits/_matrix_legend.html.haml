-# Inline legend for the Test × Computer matrix. One swatch per
-# cell kind so the user only has to learn the encoding once. Kept
-# small (16×16 swatches) so it doesn't dominate the matrix it
-# describes.

.flex.flex-wrap.items-center.gap-x-3.gap-y-1.text-fg-muted{ class: "text-[11px]" }
  .flex.items-center.gap-1
    .rounded-sm{ style: "width: 14px; height: 14px; background: var(--color-success);" }
    %span pass
  .flex.items-center.gap-1
    .relative.rounded-sm.flex.items-center.justify-center{ style: "width: 14px; height: 14px; background: var(--color-warning); color: white;" }
      = mesa_icon(:wrench, size: 8)
    %span FPE
  .flex.items-center.gap-1
    .relative.rounded-sm.flex.items-center.justify-center{ style: "width: 14px; height: 14px; background: var(--color-warning); color: white;" }
      = mesa_icon(:neq, size: 8)
    %span checksum ≠
  .flex.items-center.gap-1
    .relative.rounded-sm{ style: "width: 14px; height: 14px; background: var(--color-success);" }
      .absolute.flex.items-center.justify-center{ style: "top: -2px; right: -2px; width: 9px; height: 9px; border-radius: 50%; background: var(--color-info); color: white;" }
        = mesa_icon(:plus, size: 5)
    %span full inlists
  .flex.items-center.gap-1
    .rounded-sm.flex.items-center.justify-center{ style: "width: 14px; height: 14px; background: var(--color-danger); color: white;" }
      = mesa_icon(:x, size: 8)
    %span fail
  .flex.items-center.gap-1
    .rounded-sm{ style: "width: 14px; height: 14px; background: repeating-linear-gradient(45deg, var(--color-info-soft) 0 3px, var(--color-info) 3px 6px);" }
    %span pending
  .flex.items-center.gap-1
    .rounded-sm{ style: "width: 14px; height: 14px; background: repeating-linear-gradient(45deg, var(--color-bg-subtle) 0 3px, var(--color-bg-muted) 3px 6px);" }
    %span no build
