-# One swatch in the subway-map legend.
-# Locals:
-#   kind:  :core (filled disc, matches a station's center dot) or
-#          :ring (annulus, matches the surrounding test-status ring).
-#   color: CSS color value (typically a `var(--color-...)`).
-#   label: visible text after the swatch.
- if kind == :ring
  -# Build the annulus via an outer disc with a bg-color inner hole,
  -# mirroring the SVG rendering exactly.
  %span.inline-flex.items-center.gap-1
    %span.inline-block.relative{ style: "width: 14px; height: 14px;" }
      %span.absolute.inset-0.rounded-full{ style: "background: #{color};" }
      %span.absolute.rounded-full{ style: "background: var(--color-bg-elev); top: 3px; left: 3px; right: 3px; bottom: 3px;" }
    = label
- else
  %span.inline-flex.items-center.gap-1
    %span.inline-block.rounded-full{ style: "width: 8px; height: 8px; background: #{color};" }
    = label
