-# Compact sparkline for the commit detail hero. Renders the last N
-# commits on this branch as small two-tone bars (top sliver = build
-# status, bottom block = tests status). The focused commit (the one
-# the user is currently viewing) gets a brand-color outline.
-#
-# Locals:
-#   sparkline_data: array of { sha:, build_status:, tests_status:, commit: }
-#   focused_sha:    full SHA of the commit to outline (nil = none).
- count = sparkline_data.size
- if count.zero?
  %span.text-fg-subtle{ class: "text-[11px]" } no recent activity
- else
  - build_colors = { all_ok: "var(--color-success)", some_fail: "var(--color-warning)", all_fail: "var(--color-buildfail)", unknown: "var(--color-skipped)" }
  - tests_colors = { all_pass: "var(--color-success)", mixed: "var(--color-warning)", fail: "var(--color-danger)", pending_partial: "var(--color-info)", pending: "var(--color-skipped)", not_run: "var(--color-skipped)" }
  - bar_w = 14
  - gap = 4
  - height = 40
  - top_h = 8
  - width = (bar_w + gap) * count - gap
  - # Sparkline reads newest-on-right, matching the prototype, so reverse
  - # the newest-first array we get from `Branch#sparkline_data`.
  - bars = sparkline_data.reverse
  %svg{ viewBox: "0 0 #{width} #{height}", width: width, height: height, role: "img", "aria-label": "Last #{count} commits sparkline" }
    - bars.each_with_index do |bar, i|
      - x = i * (bar_w + gap)
      - build_color = build_colors[bar[:build_status]] || build_colors[:unknown]
      - tests_color = tests_colors[bar[:tests_status]] || tests_colors[:not_run]
      - focused = focused_sha && bar[:commit].sha == focused_sha
      %a{ href: commit_path(branch: @selected_branch.name, sha: bar[:sha]),
          title: "#{bar[:sha]} · build #{bar[:build_status]} · tests #{bar[:tests_status]}" }
        %rect{ x: x, y: 0, width: bar_w, height: top_h, fill: build_color, rx: 2 }
        %rect{ x: x, y: top_h + 2, width: bar_w, height: height - top_h - 2, fill: tests_color, rx: 2 }
        - if focused
          %rect{ x: x - 1.5, y: -1.5, width: bar_w + 3, height: height + 3,
                 fill: "none", stroke: "var(--color-brand)", "stroke-width": 1.5, rx: 3 }
