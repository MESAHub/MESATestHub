-# Hero card. Pulls from @commit, @commit_state, and @sparkline_data.
- state = @commit_state
- tests = state[:tests]
- flags = state[:flags]

.rounded-lg.border.border-border.bg-bg-elev.p-5{ style: "box-shadow: var(--shadow-card-sm);" }
  -# Top row: pill row + message + meta on the left; GitHub/Copy on the right.
  .flex.flex-wrap.items-start.gap-4
    .min-w-0.flex-1.space-y-3
      .flex.flex-wrap.items-center.gap-1.5
        = build_status_pill(state)
        = test_status_pill(state)
        - pr_number = commit_pr_number(@commit)
        - if pr_number
          %span{ class: "inline-flex items-center gap-1 rounded-full border border-transparent bg-bg-muted px-2 py-0.5 text-[11px] font-medium text-fg-muted align-middle" }
            PR ##{pr_number}
        - if flags[:fpe].to_i > 0
          %span{ class: "inline-flex items-center gap-1 rounded-full border border-transparent bg-warning-soft px-2 py-0.5 text-[11px] font-medium text-warning-soft-text align-middle" }
            = mesa_icon(:wrench, size: 11)
            #{flags[:fpe]} FPE
        - if flags[:checksum].to_i > 0
          %span{ class: "inline-flex items-center gap-1 rounded-full border border-transparent bg-warning-soft px-2 py-0.5 text-[11px] font-medium text-warning-soft-text align-middle" }
            = mesa_icon(:neq, size: 11)
            #{flags[:checksum]} checksum ≠
        - if flags[:inlists_full].to_i > 0
          %span{ class: "inline-flex items-center gap-1 rounded-full border border-transparent bg-info-soft px-2 py-0.5 text-[11px] font-medium text-info-soft-text align-middle" }
            = mesa_icon(:plus, size: 11)
            #{flags[:inlists_full]} full inlists

      -# Commit message: first line as the headline, plus a
      -# disclosure-style expander for the body when there's more
      -# than a one-liner. The `<details>` element keeps the hero
      -# compact by default and uses zero JS for the toggle.
      - message_body = @commit.message.to_s.split("\n", 2)[1]&.strip.presence
      %h1.text-xl.font-semibold.tracking-tight.text-fg= @commit.message_first_line(120)
      - if message_body
        %details.text-fg-muted{ class: "text-[12px]" }
          %summary.cursor-pointer.text-fg-subtle.hover:text-fg.transition-colors.select-none.inline-flex.items-center.gap-1{ class: "text-[11px]" }
            Show full message
          %div.mt-2.whitespace-pre-wrap.font-mono.text-fg{ class: "text-[12px]" }= message_body

      .flex.flex-wrap.items-center.gap-x-3.gap-y-1.text-fg-muted{ class: "text-[12px]" }
        .flex.items-center.gap-1.5
          = commit_avatar(@commit.author, size: 20)
          %span.text-fg= @commit.author
        %span.text-fg-subtle ·
        %span.flex.items-center.gap-1
          = mesa_icon(:clock, size: 12)
          %span committed #{time_ago_compact(@commit.commit_time)}

    .flex.flex-col.gap-1.shrink-0
      - if @commit.github_url
        = link_to @commit.github_url,
                 target: "_blank", rel: "noopener",
                 class: "mesa-btn",
                 style: "padding: 5px 12px; font-size: 12px;" do
          = mesa_icon(:github, size: 13)
          %span View on GitHub
      %button.mesa-btn{ type: "button",
                        style: "padding: 5px 12px; font-size: 12px;",
                        data: { controller: "copy-button", copy_button_text_value: @commit.sha, action: "click->copy-button#copy" } }
        = mesa_icon(:copy, size: 13)
        %span{ data: { copy_button_target: "label" } } Copy SHA

  -# Stat row + focused 5-station subway map. Stats live in the left
  -# half (compressed); the map takes the right half so the current
  -# commit's neighborhood is legible. FPE / ≠ stat is skipped when
  -# zero (the pill row above already surfaces those flags when they
  -# fire, and an always-zero tile is noise).
  - fpe_count = flags[:fpe].to_i + flags[:checksum].to_i
  - stats_columns = fpe_count.positive? ? "grid-cols-5" : "grid-cols-4"
  .mt-5.pt-4.border-t.border-border-subtle
    .grid.gap-6{ class: "grid-cols-1 md:grid-cols-2" }
      .grid.gap-3{ class: stats_columns }
        = stat_block(label: "Builds",
                     value: "#{state[:build][:built_computer_ids].size} / #{state[:build][:built_computer_ids].size + state[:build][:failed_build_computer_ids].size}",
                     color: state[:build][:status] == :all_fail ? "text-buildfail" : (state[:build][:status] == :some_fail ? "text-warning" : "text-success"))
        = stat_block(label: "Failing",
                     value: tests[:uniform_failing_tests],
                     color: tests[:uniform_failing_tests].positive? ? "text-danger" : "text-fg-subtle")
        = stat_block(label: "Mixed",
                     value: tests[:mixed_tests],
                     color: tests[:mixed_tests].positive? ? "text-warning" : "text-fg-subtle")
        = stat_block(label: "Pending",
                     value: tests[:pending_tests],
                     color: tests[:pending_tests].positive? ? "text-info" : "text-fg-subtle")
        - if fpe_count.positive?
          = stat_block(label: "FPE / ≠",
                       value: fpe_count,
                       color: "text-warning")
      .min-w-0
        %span.mesa-label.mb-1 Recent commits
        = render "commits/hero_subway_map", window: @hero_window, focused_sha: @commit.sha

  -# Full SHA footer.
  .mt-4.pt-3.border-t.border-border-subtle.flex.items-baseline.gap-3
    %span.mesa-label{ style: "min-width: 50px;" } Full SHA
    %code.font-mono.text-fg-muted.tabular-nums.break-all{ class: "text-[12px]" }= @commit.sha
