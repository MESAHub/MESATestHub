-# Pure visual matrix cell — same encoding table as `_matrix_cell`,
-# but without the link wrapper. Use this when the cell is rendered
-# alongside its own surrounding context (the diff tab's row, where
-# the entire row already links elsewhere) or as a static legend swatch.
-#
-# Locals:
-#   cell:        hash from `Commit#test_computer_matrix` (or a
-#                synthetic `{ status:, flags: }` for the diff tab's
-#                before/after pair).
-#   size:        cell edge length in px. Defaults to 22.
-#   label:       optional override for the `title` tooltip.

- attrs = matrix_cell_attrs(cell)
- bg_style = attrs[:kind] == :striped ? "background: repeating-linear-gradient(45deg, #{attrs[:bg]} 0 4px, #{attrs[:stripe]} 4px 8px);" : "background: #{attrs[:bg]};"
- size_val   = local_assigns[:size] || 22
- glyph_size = [(size_val * 0.55).round, 8].max
- corner_box = [(size_val * 0.5).round, 9].max
- corner_glyph = [(corner_box * 0.6).round, 5].max

%span.relative.inline-block.rounded-sm.align-middle{
  style: "#{bg_style} width: #{size_val}px; height: #{size_val}px;",
  title: (local_assigns[:label] || attrs[:label]) }
  - if attrs[:glyph]
    %span.absolute.inset-0.flex.items-center.justify-center{ style: "color: #{attrs[:glyph_color]};" }
      = mesa_icon(attrs[:glyph], size: glyph_size)
  - if attrs[:corner]
    %span.absolute.flex.items-center.justify-center{
      style: "top: -2px; right: -2px; width: #{corner_box}px; height: #{corner_box}px; border-radius: 50%; background: #{attrs[:corner_bg]}; color: white;" }
      = mesa_icon(attrs[:corner], size: corner_glyph)
