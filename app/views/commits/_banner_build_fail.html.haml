-# All builds failed. No test data. Locals: state, failed_ids, computers_by_id, etc.
.rounded-md.p-3{ style: "background: var(--color-buildfail-soft); border: 1px solid var(--color-buildfail);" }
  .flex.items-start.gap-3
    %span.text-buildfail-soft-text.shrink-0= mesa_icon(:x, size: 16)
    .flex-1.min-w-0.space-y-1.text-buildfail-soft-text
      %p.text-sm
        %span.font-semibold Build failed on every computer.
        %span.opacity-80.ml-1 No test data for this commit.
      - if failed_ids.any?
        %p.opacity-80{ class: "text-[11px]" }
          %span Failed:
          - failed_ids.each_with_index do |id, i|
            %span.font-mono.font-semibold.ml-1
              = computers_by_id[id]&.name || "computer ##{id}"
              = ',' unless i == failed_ids.size - 1
    %a.mesa-btn.shrink-0{ href: "?tab=computers",
                          style: "padding: 4px 10px; font-size: 12px;",
                          data: { action: "click->tabs#switchFromLink" } }
      See computers
      = mesa_icon(:arrow_right, size: 12)
