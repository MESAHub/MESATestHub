- content_for :title, "#{@commit.short_sha} · MESA Test Hub"

.space-y-4{ data: { controller: "tabs", tabs_active_value: @active_tab.to_s } }
  = render "commits/show_breadcrumb"
  = render "commits/show_hero"
  = render "commits/show_banners"
  = render "commits/show_tab_strip"

  -# Tab panels — only the active one is shown. Stimulus toggles the
  -# `hidden` attribute on each panel when the user clicks a tab,
  -# and updates `?tab=...` on the URL so the panel is bookmarkable.
  - %i[summary tests computers diff logs].each do |tab|
    %section{ data: { tabs_target: "panel", tab: tab }, hidden: (tab != @active_tab) }
      = render "commits/tab_#{tab}"
