-# Some test runs still in flight. Info-blue, no action button.
- count = state[:tests][:pending_tests]
.rounded-md.p-3{ style: "background: var(--color-info-soft); border: 1px solid var(--color-info);" }
  .flex.items-start.gap-3
    %span.text-info-soft-text.shrink-0= mesa_icon(:clock, size: 16)
    .flex-1.min-w-0.text-info-soft-text
      %p.text-sm
        %span.font-semibold= pluralize(count, "test")
        still running.
        %span.opacity-80.ml-1 Results below may be incomplete.
