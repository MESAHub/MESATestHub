-# Uniform failures present and we have a comparison anchor.
- failing_cells = state[:tests][:failing_cells]
- count = state[:tests][:uniform_failing_tests]
- tccs_by_id = @per_test.each_with_object({}) { |row, h| h[row[:test_case]&.id] = row[:test_case] if row[:test_case] }
.rounded-md.border.border-border.bg-bg-elev.p-3{ style: "border-left: 3px solid var(--color-danger);" }
  .flex.items-start.gap-3
    %span.text-danger.shrink-0= mesa_icon(:x, size: 16)
    .flex-1.min-w-0.space-y-1
      %p.text-sm
        %span.font-semibold.text-danger= pluralize(count, "test")
        failing since last passing commit
        = link_to @last_clean_commit.short_sha,
                 commit_path(branch: @selected_branch.name, sha: @last_clean_commit.short_sha),
                 class: "font-mono text-brand bg-brand-soft px-1.5 py-0.5 rounded no-underline"
      - if failing_cells.any?
        %p.text-fg-subtle{ class: "text-[11px]" }
          - failing_cells.first(3).each_with_index do |cell, i|
            - test_case = tccs_by_id[cell[:test_id]]
            - computer = computers_by_id[cell[:computer_id]]
            %span.font-mono.text-fg-muted.ml-1
              = test_case&.name || "test ##{cell[:test_id]}"
              on
              = computer&.name || "computer ##{cell[:computer_id]}"
              = ',' unless i == [failing_cells.size, 3].min - 1
          - if failing_cells.size > 3
            %span.ml-1 + #{failing_cells.size - 3} more
    %a.mesa-btn.shrink-0{ href: "?tab=diff",
                          style: "padding: 4px 10px; font-size: 12px;",
                          data: { action: "click->tabs#switchFromLink" } }
      View diff
      = mesa_icon(:arrow_right, size: 12)
