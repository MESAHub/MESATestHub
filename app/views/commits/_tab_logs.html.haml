-# Logs tab. The page proxies build logs from the Flatiron logs
-# host through `commits#build_log`; this partial just wires up
-# the picker UI and hands off to the `logs` Stimulus controller
-# for fetching + rendering. The fetch is deferred until the tab
-# becomes active (or a user clicks a computer), so opening a
-# commit that doesn't need logs costs zero bytes of upstream
-# traffic.
-#
-# Default computer selection: `per_computer_summary` is already
-# sorted worst-first, which means any `:build_fail` computer
-# floats to position 0. If nothing failed to build, the first
-# remaining sort key wins.
- default = (@per_computer.find { |r| r[:state] == :build_fail } || @per_computer.first)
- default_name = default && default[:computer]&.name

.rounded-lg.border.border-border.bg-bg-elev{ style: "box-shadow: var(--shadow-card-sm);",
                                              data: { controller: "logs",
                                                      logs_url_template_value: commit_build_log_path(branch: @selected_branch.name, sha: @commit.short_sha, computer: "__COMPUTER__"),
                                                      logs_status_url_template_value: commit_build_log_status_path(branch: @selected_branch.name, sha: @commit.short_sha, computer: "__COMPUTER__"),
                                                      logs_default_computer_value: default_name.to_s,
                                                      logs_active_tab_value: @active_tab.to_s,
                                                      logs_short_sha_value: @commit.short_sha } }
  - if @per_computer.empty?
    .px-4.py-10.text-center.text-fg-muted.text-sm No computers have submitted for this commit.
  - else
    .flex.flex-wrap.items-center.justify-between.gap-3.border-b.border-border-subtle.px-4.py-3
      .flex.items-center.gap-2.text-sm
        %span.text-fg-muted Computer:
        %span.font-mono.text-fg{ data: { logs_target: "currentLabel" } }
          = default_name || "—"
      .flex.flex-wrap.gap-1
        - @per_computer.each do |row|
          - name = row[:computer]&.name
          - next unless name
          - active = (name == default_name)
          %button{ type: "button",
                   class: "rounded-md border px-2 py-1 text-[11px] font-mono cursor-pointer transition-colors " +
                          (active ? "border-brand bg-brand-soft text-brand-soft-text" : "border-border bg-bg-elev text-fg-muted hover:bg-bg-muted"),
                   data: { logs_target: "computerButton",
                           logs_computer: name,
                           logs_state: row[:state].to_s,
                           action: "click->logs#selectComputer" } }
            %span{ class: "inline-block h-1.5 w-1.5 rounded-full mr-1 #{status_dot_class_for_computer(row[:state])}" }
            = name

    .px-4.py-4
      .relative.rounded-md.border.border-border-subtle.bg-bg-subtle.overflow-hidden{ data: { logs_target: "frame" } }
        -# Download link, floating in the top-right corner. The
        -# `download` HTML attribute is honored on same-origin URLs
        -# and triggers a save-as instead of opening the log inline.
        -# The controller refreshes both `href` and `download` when
        -# the user picks a different computer.
        - if default_name
          = link_to commit_build_log_path(branch: @selected_branch.name, sha: @commit.short_sha, computer: default_name),
                   download: "build_log_#{@commit.short_sha}_#{default_name}.log",
                   title: "Download this build log",
                   class: "absolute top-2 right-2 z-10 inline-flex items-center gap-1 rounded-md border border-border bg-bg-elev px-2 py-1 text-fg-muted hover:bg-bg-muted hover:text-fg no-underline",
                   style: "box-shadow: var(--shadow-card-sm); font-size: 11px;",
                   data: { logs_target: "downloadLink" } do
            = mesa_icon(:download, size: 13)
            %span Download
        -# Placeholder shown until the controller swaps in real content.
        .py-12.text-center.text-fg-muted.text-sm{ data: { logs_target: "placeholder" } }
          %span Click the Build logs tab to load the build log…
        %pre.hidden.overflow-auto.p-4.font-mono.leading-relaxed.text-fg{ data: { logs_target: "content" }, class: "text-[12px] whitespace-pre-wrap break-words", style: "max-height: 60vh;" }
