- content_for :title, "Search test instances"

.space-y-4
  -# Top-level page, no back arrow.
  %nav.flex.flex-wrap.items-center.gap-2.text-sm.text-fg-muted
    %span.text-fg Test instances

  -# Headline card.
  .rounded-lg.border.border-border.bg-bg-elev.p-5{ style: "box-shadow: var(--shadow-card-sm);" }
    %div{ class: "text-[20px] font-medium leading-snug tracking-tight text-fg" }
      Search test instances
    %p.mt-2.text-fg-muted{ class: "text-[13px]" }
      Cross-cuts every test run on every computer for every commit
      using a single key-value query language.

  -# Known-broken warning. The search backend
  -# (`TestInstance.query` in app/models/test_instance.rb) has
  -# rotted since the SVN→git transition — `version:` queries hit
  -# the long-gone `Version` model + dropped `mesa_version`
  -# column and silently fall through (`flash.now[:warning]`).
  -# Other fields like `test_case:`, `user:`, `commit:` mostly
  -# still work. The JSON API at `/test_instances/search.json`
  -# shares the same backend.
  .rounded-md.border.border-warning.bg-warning-soft.p-3.text-warning-soft-text{ role: "status" }
    .flex.items-start.gap-2
      = mesa_icon(:warn, size: 14, css: "mt-0.5 shrink-0")
      .min-w-0
        %p.font-semibold{ class: "text-[13px]" } Partial functionality — known rot.
        %p.mt-1{ class: "text-[12px]" }
          The query backend has rotted since the SVN → git
          transition. Some fields still work
          (#{content_tag(:code, "test_case", class: "font-mono")},
          #{content_tag(:code, "user", class: "font-mono")},
          #{content_tag(:code, "commit", class: "font-mono")},
          #{content_tag(:code, "computer", class: "font-mono")},
          #{content_tag(:code, "passed", class: "font-mono")}); others
          (notably #{content_tag(:code, "version", class: "font-mono")}, which depends on the dropped
          `mesa_version` column + retired `Version` model) silently
          drop through and return the unfiltered result set. The
          JSON API (#{content_tag(:code, "/test_instances/search.json", class: "font-mono")})
          shares the same backend. Repairing the query layer is a
          separate, deferred task.

  -# Search form.
  = form_with url: search_instances_path, method: :get, local: true, class: "rounded-lg border border-border bg-bg-elev p-5 space-y-3", html: { style: "box-shadow: var(--shadow-card-sm);" } do |f|
    %div
      %label.mesa-label.mb-1{ for: "search-query" } Query
      .flex.flex-wrap.items-stretch.gap-2
        = text_field_tag :query_text, params[:query_text],
                         id: "search-query",
                         placeholder: "user: Bill Wolf; test_case: 1M_pre_ms_to_wd",
                         class: "mesa-input font-mono flex-1",
                         style: "min-width: 280px;"
        %button.mesa-btn.mesa-btn-primary{ type: "submit", style: "padding: 6px 16px; font-size: 13px;" }
          = mesa_icon(:search, size: 12)
          %span Search

  -# Collapsible syntax reference. Using <details> so we get the
  -# expand/collapse for free, no Stimulus needed. The "open"
  -# attribute auto-opens it when @show_instructions is true (the
  -# controller sets that when no query has been submitted).
  %details.rounded-lg.border.border-border.bg-bg-elev{ open: @show_instructions, style: "box-shadow: var(--shadow-card-sm);" }
    %summary.flex.items-center.justify-between.gap-2.px-5.py-3.cursor-pointer.hover:bg-bg-muted{ class: "[&::-webkit-details-marker]:hidden" }
      %span.mesa-label Query syntax
      = mesa_icon(:chevron, size: 12, css: "text-fg-muted")
    .border-t.border-border-subtle.p-5.space-y-5

      -# Three usage patterns side-by-side at lg+.
      .grid.gap-5{ class: "grid-cols-1 lg:grid-cols-3 text-[13px]" }
        .min-w-0
          %h4.font-semibold.text-fg.mb-2{ class: "text-[13px]" } Simple queries
          %p.text-fg-muted
            Enter key-value pairs separated by a colon. For example
          %p.mt-2
            %code.font-mono.text-fg{ class: "rounded-md bg-bg-muted px-2 py-0.5 text-[12px]" } user: Bill Wolf
          %p.mt-2.text-fg-muted
            returns every test instance submitted by Bill Wolf.
            Always put a space after the colon.

        .min-w-0
          %h4.font-semibold.text-fg.mb-2{ class: "text-[13px]" } Compound queries
          %p.text-fg-muted
            String multiple pairs together with semicolons:
          %p.mt-2
            %code.font-mono.text-fg{ class: "rounded-md bg-bg-muted px-2 py-0.5 text-[12px]" } user: Bill Wolf; version: 10000
          %p.mt-2.text-fg-muted
            All conditions are combined with AND.

        .min-w-0
          %h4.font-semibold.text-fg.mb-2{ class: "text-[13px]" } Ranges and lists
          %p.text-fg-muted
            Comma-separate values for OR, or use a dash for ranges:
          %p.mt-2
            %code.font-mono.text-fg{ class: "rounded-md bg-bg-muted px-2 py-0.5 text-[12px]" } version: 10000-10200; test_case: wd2, 1M_thermohaline

      -# Available fields, two columns.
      %div
        %h4.font-semibold.text-fg.mb-3{ class: "text-[13px]" } Available fields
        .grid.gap-x-8.gap-y-1{ class: "grid-cols-1 md:grid-cols-2 text-[13px]" }
          %dl.space-y-2
            = render "field_row", field: "test_case", desc: "Name of a valid test case."
            = render "field_row", field: "version", desc: "Number of a valid MESA revision."
            = render "field_row", field: "passed", desc: %q{"t" / "true" / "f" / "false" — match passing or failing instances.}
            = render "field_row", field: "computer", desc: "Name of a computer."
            = render "field_row", field: "user", desc: "Name of a user (maintainer)."
            = render "field_row", field: "date", desc: "Submission date — YYYY/MM/DD, UTC."
            = render "field_row", field: "datetime", desc: "Submission date and time — YYYY/MM/DD hh:mm:ss; append e.g. 'PST' for a non-UTC timezone."
            = render "field_row", field: "platform", desc: "Computer platform: macOS or linux. No version string."
          %dl.space-y-2
            = render "field_row", field: "platform_version", desc: "Platform version, e.g. 14.5 or Ubuntu 22.04."
            = render "field_row", field: "rn_runtime / re_runtime / runtime", desc: "Runtime for rn / re scripts or whole test. Integer seconds or '1 hr 30 min', '2.3 hours', etc."
            = render "field_row", field: "rn_RAM / re_RAM", desc: "Peak memory for rn / re scripts, in GB."
            = render "field_row", field: "threads", desc: "Number of OpenMP threads used."
            = render "field_row", field: "compiler", desc: "Compiler family, e.g. SDK, gfortran, ifort."
            = render "field_row", field: "compiler_version", desc: "Compiler version string. Format varies; SDK uses e.g. x86_64-osx-10.10-10.14-20190408."

  -# Results.
  - if @test_instances.nil?
    -# No query yet. The syntax-reference details panel is already
    -# auto-open via @show_instructions=true; no extra empty state
    -# needed here.
  - elsif @test_instances.empty?
    .rounded-lg.border.border-border.bg-bg-elev.p-10.text-center.text-fg-muted.text-sm{ style: "box-shadow: var(--shadow-card-sm);" }
      No test instances matched the query.
      - if flash.now[:warning].present?
        .mt-2.text-fg-subtle{ class: "text-[12px]" }= flash.now[:warning]
  - else
    .rounded-lg.border.border-border.bg-bg-elev.overflow-hidden{ style: "box-shadow: var(--shadow-card-sm);" }
      .flex.flex-wrap.items-baseline.justify-between.gap-3.px-4.py-3.border-b.border-border-subtle
        %div
          %span.mesa-label Results
          %span.ml-2.text-fg{ class: "text-[14px]" }
            = pluralize(@test_instances.total_count, "test instance")
            matched
        - if @test_instances.total_pages > 1
          %span.text-fg-subtle.tabular-nums{ class: "text-[11px]" }
            = page_entries_info @test_instances

      %div{ style: "overflow-x: auto;" }
        %table.w-full.border-collapse{ style: "min-width: 1000px;" }
          %thead.bg-bg-subtle
            %tr.text-fg-muted{ class: "text-[11px] uppercase tracking-wide" }
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Commit
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Test case
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Status
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Computer
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap User
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Submitted
              %th.text-right.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Runtime (s)
              %th.text-right.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap RAM (GB)
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Compiler
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Platform
              %th.text-right.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Threads
          %tbody
            - @test_instances.each do |ti|
              - next unless ti.commit
              %tr.border-b.border-border-subtle.align-middle.hover:bg-bg-subtle{ class: "[&>td]:py-2" }
                %td.px-3.font-mono.whitespace-nowrap{ class: "text-[12px]" }
                  = link_to ti.commit.short_sha,
                           commit_path(branch: "main", sha: ti.commit.short_sha),
                           class: "text-brand font-semibold no-underline hover:underline"
                %td.px-3.font-mono.whitespace-nowrap{ class: "text-[12px]" }
                  = link_to ti.test_case.name,
                           test_case_commit_path(branch: "main", module: ti.test_case.module, test_case: ti.test_case.name, sha: ti.commit.short_sha),
                           class: "text-fg-muted hover:text-brand no-underline"
                %td.px-3.whitespace-nowrap{ class: "text-[12px]" }
                  - if ti.passed
                    %span.inline-flex.items-center.gap-1.rounded-md.bg-success-soft.text-success-soft-text{ class: "text-[11px] font-medium", style: "padding: 1px 8px;" }
                      = mesa_icon(:check, size: 11)
                      %span= ti.passage_status
                  - else
                    %span.inline-flex.items-center.gap-1.rounded-md.bg-danger-soft.text-danger-soft-text{ class: "text-[11px] font-medium", style: "padding: 1px 8px;" }
                      = mesa_icon(:x, size: 11)
                      %span= ti.passage_status
                %td.px-3.whitespace-nowrap{ class: "text-[12px]" }
                  = link_to ti.computer.name,
                           user_computer_path(ti.computer.user, ti.computer),
                           class: "font-mono text-fg hover:text-brand no-underline"
                %td.px-3.whitespace-nowrap{ class: "text-[12px]" }
                  = link_to ti.computer.user.name, user_path(ti.computer.user),
                           class: "text-fg-muted hover:text-brand no-underline"
                %td.px-3.text-fg-muted.whitespace-nowrap{ class: "text-[12px] tabular-nums" }
                  = format_time_tag(ti.created_at)
                %td.px-3.text-right.font-mono.tabular-nums.whitespace-nowrap{ class: "text-[12px]" }
                  = ti.runtime_seconds || 0
                  %span.text-fg-subtle  /
                  = ti.re_time || 0
                  %span.text-fg-subtle  /
                  = ti.total_runtime_seconds || 0
                %td.px-3.text-right.font-mono.tabular-nums.whitespace-nowrap{ class: "text-[12px]" }
                  = sprintf('%.2f', ti.rn_mem_GB || 0)
                  %span.text-fg-subtle  /
                  = sprintf('%.2f', ti.re_mem_GB || 0)
                %td.px-3.font-mono.text-fg-muted.whitespace-nowrap{ class: "text-[12px]" }
                  = [ti.compiler, ti.compiler_version].compact_blank.join(' ').presence || content_tag(:span, "—", class: "text-fg-subtle")
                %td.px-3.font-mono.text-fg-muted.whitespace-nowrap{ class: "text-[12px]" }
                  = [ti.computer.platform, ti.platform_version].compact_blank.join(' ').presence || content_tag(:span, "—", class: "text-fg-subtle")
                %td.px-3.text-right.font-mono.tabular-nums.whitespace-nowrap{ class: "text-[12px]" }
                  = ti.omp_num_threads || content_tag(:span, "—", class: "text-fg-subtle")

    - if @test_instances.total_pages > 1
      .pt-2
        = paginate @test_instances, theme: "modern"
