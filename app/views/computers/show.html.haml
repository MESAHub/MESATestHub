- content_for :title, "#{@computer.name} · #{@user.name}"

.space-y-4
  -# Breadcrumb. Back arrow lands on the user's computer list (the
  -# natural "up"), mirroring the test-on-commit / test-case-show
  -# breadcrumb pattern.
  %nav.flex.flex-wrap.items-center.gap-2.text-sm.text-fg-muted
    = link_to user_computers_path(@user),
             class: "inline-flex items-center gap-1 rounded-md px-2 py-1 hover:bg-bg-muted hover:text-fg no-underline",
             title: "Back to #{@user.name}'s computers" do
      = mesa_icon(:arrow_left, size: 14)
      %span= "#{@user.name}'s computers"
    %span.text-fg-subtle /
    %span.font-mono.text-fg= @computer.name

  -# Headline card. Two tiers separated by a hairline, mirroring
  -# test_case_commits/_headline. Tier 1 is the identity sentence
  -# ("<name> is a <platform> machine maintained by <user>") with
  -# Edit/Delete actions top-right. Tier 2 splits at lg+ between
  -# hardware identity (left) and CPU-hours usage capsule (right);
  -# below lg the columns stack.
  .rounded-lg.border.border-border.bg-bg-elev.p-5{ style: "box-shadow: var(--shadow-card-sm);" }

    -# Tier 1.
    .flex.flex-wrap.items-start.justify-between.gap-3
      %div.min-w-0
        %div{ class: "text-[22px] font-medium leading-snug tracking-tight text-fg" }
          %span.font-mono.font-semibold.text-fg= @computer.name
          %span.text-fg-muted{ class: "text-[20px]" }<>
            = " is a "
          - if @computer.platform.present?
            %span.font-mono.font-semibold.text-fg= @computer.platform
            %span.text-fg-muted{ class: "text-[20px]" }<>
              = " machine maintained by "
          - else
            %span.text-fg-muted{ class: "text-[20px]" }<>
              = "machine maintained by "
          = link_to @user.name, user_path(@user),
                   class: "font-semibold text-brand no-underline hover:underline"

      - if self_or_admin?
        .shrink-0.flex.items-center.gap-1
          = link_to edit_user_computer_path(@user, @computer),
                   class: "mesa-btn",
                   style: "padding: 4px 10px; font-size: 12px;" do
            %span Edit
          = button_to user_computer_path(@user, @computer),
                     method: :delete,
                     form: { data: { turbo_confirm: "Delete #{@computer.name}? This removes all associated submissions and test instances." } },
                     class: "mesa-btn",
                     style: "padding: 4px 10px; font-size: 12px; color: var(--color-danger-soft-text); border-color: var(--color-danger-soft); background: transparent;" do
            Delete

    -# Tier 2.
    .mt-4.pt-4.border-t.border-border-subtle.grid.gap-6{ class: "grid-cols-1 lg:grid-cols-2" }

      -# LEFT — hardware identity.
      .min-w-0
        %span.mesa-label.mb-3 Hardware
        %dl.mt-2.grid.gap-y-2{ class: "grid-cols-[auto_1fr] gap-x-6 text-[13px]" }
          %dt.text-fg-subtle Platform
          %dd.text-fg
            - if @computer.platform.present?
              %span.inline-flex.items-center.gap-1.rounded-md.border.border-border.bg-bg-muted.px-2.py-0.5.font-mono.text-fg{ class: "text-[11px]" }= @computer.platform
            - else
              %span.text-fg-subtle —
          %dt.text-fg-subtle Processor
          %dd.text-fg= @computer.processor.presence || content_tag(:span, "—", class: "text-fg-subtle")
          %dt.text-fg-subtle RAM
          %dd.text-fg.font-mono.tabular-nums
            - if @computer.ram_gb.present?
              = @computer.ram_gb
              %span.text-fg-subtle  GB
            - else
              %span.text-fg-subtle —

      -# RIGHT — CPU-hours usage capsule.
      .min-w-0
        %span.mesa-label.mb-3 Usage (CPU hours)
        - cpu_rows = [["Last 24 hours", @cpu_times[:day]], ["Last year", @cpu_times[:year]], ["All time", @cpu_times[:all]]]
        %dl.mt-2.grid.gap-y-2{ class: "grid-cols-[auto_1fr] gap-x-6 text-[13px]" }
          - cpu_rows.each do |label, hours|
            %dt.text-fg-subtle= label
            %dd.font-mono.tabular-nums.text-fg
              = format('%.3g', hours.to_f)
              %span.text-fg-subtle  h
          %dt.text-fg-subtle Since
          %dd.text-fg-muted{ class: "text-[12px]" }= format_date(@earliest)

  -# Submissions card. The whole thing — header band, filter form,
  -# selection bar, table, modal — sits under a single
  -# `submission-selection` Stimulus controller scope so the
  -# checkbox state, the bar, and the modal all read from the same
  -# target set. The filter form is a separate inner form (GET to
  -# the same URL); the modal contains its own DELETE form so the
  -# table itself isn't wrapped in a form at all (avoids nesting
  -# issues with the pagination links that live below it).
  - filter_active = @filter[:from] || @filter[:to] || @filter[:sha] || @filter[:type]
  - total_matching = @submissions_scope.unscope(:order, :limit, :offset).count
  - visible_count = @submissions.size
  - can_delete = self_or_admin?
  - has_no_submissions_at_all = !filter_active && @computer.submissions.none?

  .rounded-lg.border.border-border.bg-bg-elev.overflow-hidden{ style: "box-shadow: var(--shadow-card-sm);", data: ({ controller: "submission-selection", submission_selection_total_matching_value: total_matching, submission_selection_visible_count_value: visible_count } if can_delete) }

    -# Header band — title + page-info.
    .flex.flex-wrap.items-baseline.justify-between.gap-3.px-4.py-3.border-b.border-border-subtle
      %div
        %span.mesa-label Submissions
        %span.ml-2.text-fg{ class: "text-[14px]" }
          = pluralize(total_matching, "submission")
          - if filter_active
            matching the filter
          - else
            on
            %span.font-mono= @computer.name
      - if @submissions.total_pages > 1
        %span.text-fg-subtle.tabular-nums{ class: "text-[11px]" }
          = page_entries_info @submissions

    -# Filter toolbar. GET form — submits to the same URL with the
    -# active filter params. Three inputs: from / to / sha. The
    -# pickers stay quiet when empty (no labels); on focus the
    -# placeholder makes their intent clear. "Reset" only appears
    -# when at least one filter is active.
    = form_tag user_computer_path(@user, @computer), method: :get, class: "flex flex-wrap items-end gap-2 px-4 py-3 border-b border-border-subtle bg-bg-subtle/40" do
      %div
        %label.mesa-label.mb-1{ for: "filter-from" } From
        = date_field_tag :from, @filter[:from_raw],
                         id: "filter-from",
                         class: "mesa-input",
                         style: "width: 150px; padding: 4px 8px; font-size: 12px;"
      %div
        %label.mesa-label.mb-1{ for: "filter-to" } To
        = date_field_tag :to, @filter[:to_raw],
                         id: "filter-to",
                         class: "mesa-input",
                         style: "width: 150px; padding: 4px 8px; font-size: 12px;"
      %div
        %label.mesa-label.mb-1{ for: "filter-sha" } Commit SHA
        = text_field_tag :sha, @filter[:sha_raw],
                         id: "filter-sha",
                         placeholder: "abc1234",
                         class: "mesa-input font-mono",
                         style: "width: 180px; padding: 4px 8px; font-size: 12px;"
      -# Submission type — Empty (build only) vs Individual (one
      -# test) vs Combined (build + entire suite). Native <select>
      -# stays in the form so Apply submits it alongside the other
      -# filters; mesa-input gives the surrounding border + padding
      -# while the browser handles the chevron and selection list.
      - type_options = [["All types", ""], ["Empty (build only)", "empty"], ["Individual test", "individual"], ["Combined (build + suite)", "combined"]]
      %div
        %label.mesa-label.mb-1{ for: "filter-type" } Type
        = select_tag :type, options_for_select(type_options, @filter[:type]),
                     id: "filter-type",
                     class: "mesa-input",
                     style: "width: 200px; padding: 4px 8px; font-size: 12px;"
      .flex.items-center.gap-2
        %button.mesa-btn.mesa-btn-primary{ type: "submit", style: "padding: 5px 12px; font-size: 12px;" } Apply
        - if filter_active
          = link_to "Reset", user_computer_path(@user, @computer),
                   class: "text-fg-muted hover:text-fg no-underline",
                   style: "font-size: 12px;"

    -# Selection bar — appears when at least one row is checked.
    -# Only rendered for users who can delete; otherwise dead UI.
    - if can_delete
      .flex.flex-wrap.items-center.justify-between.gap-3.px-4.py-2.border-b.border-border-subtle.bg-brand-soft.text-brand-soft-text{ hidden: true, data: { submission_selection_target: "selectionBar" } }
        .flex.flex-wrap.items-center.gap-3{ class: "text-[12px]" }
          %strong.tabular-nums{ data: { submission_selection_target: "count" } } 0
          %span selected
          - if total_matching > visible_count
            %a{ href: "#", hidden: true, class: "underline hover:no-underline", data: { submission_selection_target: "allMatchingToggle", action: "click->submission-selection#selectAllMatching" } }
              Select all
              %span.tabular-nums= total_matching
              matching the filter
        .flex.items-center.gap-2
          %button{ type: "button", class: "mesa-btn", style: "padding: 4px 10px; font-size: 12px; color: var(--color-danger-soft-text); border-color: var(--color-danger-soft);", data: { action: "click->submission-selection#openConfirm" } }
            = mesa_icon(:x, size: 11)
            %span Delete selected
          %a.text-fg-muted.hover:text-fg.no-underline{ href: "#", class: "text-[12px]", data: { action: "click->submission-selection#clear" } } Clear

    -# Table — or empty state.
    - if has_no_submissions_at_all
      .px-4.py-10.text-center.text-fg-muted.text-sm
        No submissions from
        %span.font-mono.text-fg= @computer.name
        yet.
    - elsif @submissions.empty?
      .px-4.py-10.text-center.text-fg-muted.text-sm
        No submissions match the current filter.
        = link_to "Reset", user_computer_path(@user, @computer),
                 class: "text-brand no-underline hover:underline"
    - else
      %div{ style: "overflow-x: auto;" }
        %table.w-full.border-collapse{ style: "min-width: 820px;" }
          %thead.bg-bg-subtle
            %tr.text-fg-muted{ class: "text-[11px] uppercase tracking-wide" }
              - if can_delete
                %th.px-3.py-2.font-medium.border-b.border-border-subtle{ style: "width: 28px;" }
                  %input{ type: "checkbox", "aria-label": "Select all submissions on this page", data: { submission_selection_target: "allCheckbox", action: "change->submission-selection#toggleAll" } }
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Submitted
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Commit
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Build
              %th.text-right.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Tests
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Compiler
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap SDK
              %th.text-left.px-3.py-2.font-medium.border-b.border-border-subtle.whitespace-nowrap Math backend
          %tbody
            - @submissions.each do |submission|
              - count = @counts[submission]
              - sole = count == 1 ? submission.test_instances.first&.test_case : nil
              %tr.border-b.border-border-subtle.align-middle.hover:bg-bg-subtle{ class: "[&>td]:py-2", data: ({ submission_selection_target: "row" } if can_delete) }
                - if can_delete
                  %td.px-3
                    %input{ type: "checkbox", value: submission.id, "aria-label": "Select submission #{submission.id}", data: { submission_selection_target: "checkbox", action: "change->submission-selection#toggle" } }
                %td.px-3.text-fg-muted.whitespace-nowrap{ class: "text-[12px] tabular-nums" }
                  = format_time(submission.created_at)
                %td.px-3.font-mono.whitespace-nowrap{ class: "text-[12px]" }
                  - if submission.commit
                    = link_to submission.commit.short_sha,
                             commit_path(branch: "main", sha: submission.commit.short_sha),
                             class: "text-brand font-semibold no-underline hover:underline",
                             title: submission.commit.message_first_line(120)
                  - else
                    %span.text-fg-subtle —
                %td.px-3.whitespace-nowrap{ class: "text-[12px]" }
                  - case submission.compiled
                  - when true
                    %span.inline-flex.items-center.gap-1.rounded-md.bg-success-soft.px-2.py-0.5.text-success-soft-text{ class: "text-[11px] font-medium" }
                      = mesa_icon(:check, size: 11)
                      %span Built
                  - when false
                    %span.inline-flex.items-center.gap-1.rounded-md.bg-buildfail-soft.px-2.py-0.5.text-buildfail-soft-text{ class: "text-[11px] font-medium" }
                      = mesa_icon(:x, size: 11)
                      %span Failed
                  - else
                    %span.inline-flex.items-center.gap-1.rounded-md.bg-bg-muted.px-2.py-0.5.text-fg-subtle{ class: "text-[11px] font-medium" }
                      = mesa_icon(:eye_off, size: 11)
                      %span Not reported
                %td.px-3.text-right.font-mono.tabular-nums.whitespace-nowrap{ class: "text-[12px]" }
                  - if count.to_i.zero?
                    %span.text-fg-subtle —
                  - elsif sole
                    = link_to sole.name,
                             test_case_path(branch: "main", module: sole.module, test_case: sole.name),
                             class: "text-fg-muted hover:text-brand no-underline"
                  - else
                    = count
                %td.px-3.font-mono.text-fg-muted.whitespace-nowrap{ class: "text-[12px]" }
                  - compiler = [submission.compiler, submission.compiler_version].compact_blank.join(' ').presence
                  = compiler || content_tag(:span, "—", class: "text-fg-subtle")
                %td.px-3.font-mono.text-fg-muted.whitespace-nowrap{ class: "text-[12px]" }
                  = submission.sdk_version.presence || content_tag(:span, "—", class: "text-fg-subtle")
                %td.px-3.font-mono.text-fg-muted.whitespace-nowrap{ class: "text-[12px]" }
                  = submission.math_backend.presence || content_tag(:span, "—", class: "text-fg-subtle")

    -# Confirm-delete modal. Rendered alongside the table inside
    -# the same Stimulus scope so the controller can wire its
    -# `idsContainer` target to inputs that ultimately POST.
    -# Uses HTML5 `<dialog>` — `showModal()` gives a free backdrop,
    -# ESC handling, and focus trap on modern browsers.
    - if can_delete
      %dialog.rounded-lg.border.border-border.bg-bg-elev.p-0{ style: "box-shadow: var(--shadow-card-lg); max-width: 480px;", data: { submission_selection_target: "modal", action: "click->submission-selection#backdropClose" } }
        .p-6
          %h3.text-fg.font-semibold{ class: "text-[16px]" }
            Delete
            %span.tabular-nums{ data: { submission_selection_target: "count" } } 0
            submissions?
          %p.mt-3.text-fg-muted{ class: "text-[13px]" }
            This permanently removes
            %strong{ data: { submission_selection_target: "modalSummary" } } 0 selected submissions
            from
            %span.font-mono.text-fg= @computer.name
            along with every test instance and inlist record they reference.
            %strong This cannot be undone.
          .mt-6.flex.items-center.justify-end.gap-2
            %button.mesa-btn{ type: "button", style: "padding: 6px 14px; font-size: 13px;", data: { action: "click->submission-selection#closeConfirm" } } Cancel
            = form_tag destroy_computer_submissions_path(user_id: @user.id, id: @computer.id), method: :delete, class: "inline" do
              -# Preserve active filter so the post-delete redirect
              -# lands on the same view the user was looking at.
              - if @filter[:from_raw].present?
                = hidden_field_tag :from, @filter[:from_raw]
              - if @filter[:to_raw].present?
                = hidden_field_tag :to, @filter[:to_raw]
              - if @filter[:sha_raw].present?
                = hidden_field_tag :sha, @filter[:sha_raw]
              - if @filter[:type].present?
                = hidden_field_tag :type, @filter[:type]
              %div{ data: { submission_selection_target: "idsContainer" } }
              %button{ type: "submit", class: "mesa-btn", style: "padding: 6px 14px; font-size: 13px; background: var(--color-danger); border-color: var(--color-danger); color: var(--color-danger-fg);" }
                Delete
                %span.tabular-nums{ data: { submission_selection_target: "count" } } 0
                submissions

  -# Pagination.
  - if @submissions.total_pages > 1
    .pt-2
      = paginate @submissions, theme: "modern"
