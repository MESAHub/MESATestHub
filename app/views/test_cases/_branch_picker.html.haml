-# Inline branch chip + dropdown for the test_cases#show headline.
-# Sister of commits/_branch_picker, but each option keeps the user
-# on the same test case (re-rendering its history on the chosen
-# branch) rather than dropping back to the commits index.
.relative.inline-flex.align-middle{ data: { controller: "dropdown", open: "false" } }
  %button.inline-flex.items-center.gap-2.rounded-md.px-2.5.py-1.text-sm.font-mono.text-brand-soft-text.bg-brand-soft.hover:bg-brand-soft.border.border-brand-soft.cursor-pointer{
    type: "button",
    "aria-haspopup": "listbox",
    "aria-expanded": "false",
    data: { dropdown_target: "trigger", action: "click->dropdown#toggle" } }
    %span.text-brand= mesa_icon(:branch, size: 13)
    %span= @selected_branch.name
    %span.text-brand-soft-text= mesa_icon(:chevron, size: 12)

  .absolute.left-0.top-full.z-10.mt-1.w-72.rounded-md.border.border-border.bg-bg-elev.p-1.text-sm{
    hidden: true,
    style: "box-shadow: var(--shadow-card-md);",
    data: { dropdown_target: "menu" } }
    .max-h-80.overflow-y-auto
      - [["Recently updated", @recent_branches], ["Older", @older_branches]].each do |label, branches|
        - next if branches.blank?
        .px-2.pt-2.pb-1.text-fg-subtle.uppercase.tracking-wide{ class: "text-[10px]" }= label
        - branches.each do |b|
          - active = (b.name == @selected_branch.name)
          = link_to test_case_path(branch:    b.name,
                                   module:    @test_case.module,
                                   test_case: @test_case.name),
                   class: "flex items-center justify-between gap-2 rounded-md px-2 py-1.5 font-mono no-underline #{active ? 'bg-brand text-fg-on-brand' : 'text-fg hover:bg-bg-muted'}",
                   style: "font-size: 12px;" do
            %span.flex.items-center.gap-1.5.truncate
              %span= mesa_icon(:branch, size: 11)
              = b.name
            - if active
              %span.uppercase.tracking-wide.opacity-80{ class: "text-[10px]" } current
