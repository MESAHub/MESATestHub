- content_for :title, "#{@test_case.module}/#{@test_case.name} · history"

-# Same Turbo-snapshot opt-out the test-on-commit page uses — the
-# tabs controller updates `?tab=…` via history.replaceState and
-# back-nav can otherwise show the prior body under the new URL.
- content_for :head_extras do
  %meta{ name: "turbo-cache-control", content: "no-cache" }

.space-y-4{ data: { controller: "tabs", tabs_active_value: @active_tab.to_s } }
  = render "breadcrumb"
  = render "headline"
  = render "show_tab_strip"

  -# All three panels render up-front; the tabs controller toggles
  -# `hidden` between them and updates `?tab=…` in the URL.
  - %i[history trend submissions].each do |tab|
    %section{ data: { tabs_target: "panel", tab: tab }, hidden: (tab != @active_tab) }
      = render "tab_#{tab}"
