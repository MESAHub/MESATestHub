-# Tab strip for the test-on-commit page. Two tabs:
-#   summary — instances table + filter toolbar + icon legend
-#   logs    — proxied out/mk/err viewer
-# Default is summary; the Logs tab can flip to aria-disabled at
-# runtime if the test_logs controller's probe says no upstream
-# logs exist for any computer.
- tab_specs = [[:summary, "Summary"], [:logs, "Logs"]]

%nav.flex.gap-1.border-b.border-border-subtle{ role: "tablist", "aria-label": "Test-on-commit panel" }
  - tab_specs.each do |id, label|
    - active = (id == @active_tab)
    - href = test_case_commit_path(branch: @selected_branch.name,
                                   sha: @commit.short_sha,
                                   module: @test_case.module,
                                   test_case: @test_case.name,
                                   tab: id)
    - active_class = active ? "text-fg border-brand -mb-px" : "text-fg-muted border-transparent hover:text-fg"
    - link_class = "inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium no-underline border-b-2 #{active_class}"
    = link_to href,
              role: "tab",
              "aria-selected": active.to_s,
              class: link_class,
              data: { tabs_target: "link", tab: id, action: "click->tabs#switch" } do
      = label
