- content_for :title, "#{@test_case.name} · #{@commit.short_sha}"

-# Opt this page out of Turbo Drive's snapshot cache. Same reason
-# as commits/show: the tabs controller does `history.replaceState`
-# to keep `?tab=…` bookmarkable, and that desynchronises Turbo's
-# URL tracking enough that browser-back can leave URL and body
-# out of sync. Forcing a fresh fetch on back nav avoids the
-# snapshot-vs-URL mismatch.
- content_for :head_extras do
  %meta{ name: "turbo-cache-control", content: "no-cache" }

.space-y-4{ data: { controller: "tabs", tabs_active_value: @active_tab.to_s } }
  = render "breadcrumb"
  = render "headline"
  = render "show_tab_strip"

  -# Tab panels — both render up-front; the tabs controller
  -# toggles `hidden` between them and updates `?tab=…` in the URL.
  - %i[summary logs].each do |tab|
    %section{ data: { tabs_target: "panel", tab: tab }, hidden: (tab != @active_tab) }
      = render "tab_#{tab}"
