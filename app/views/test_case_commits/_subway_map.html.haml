-# Test-case-scoped subway map. Sister of the commit-detail hero's
-# `_hero_subway_map`, but each station shows just ONE color — this
-# test's status on that commit — rather than the inner-core/outer-
-# ring split commit-show uses to encode build status separately.
-# Five stations centered on the focused commit, anchor enlarged
-# and brand-ringed; stations link to the matching test-on-commit
-# page. Hover/focus reveals a popover (SHA · age · message ·
-# author · this test's status) via the shared `subway-map`
-# Stimulus controller.
-#
-# Locals (defaulted via local_assigns):
-#   window:         Array of Commit, newest-first (focused_commit_window).
-#   tccs_by_commit: { commit_id => TestCaseCommit } lookup.
-#   focused_sha:    full SHA of the currently-rendered commit.
-#   test_case:      the TestCase scoping the map.
-#   branch:         Branch the user is browsing.

- window         = local_assigns.fetch(:window)
- tccs_by_commit = local_assigns.fetch(:tccs_by_commit)
- focused_sha    = local_assigns.fetch(:focused_sha)
- test_case      = local_assigns.fetch(:test_case)
- branch         = local_assigns.fetch(:branch)
- count = window.size
- if count.zero?
  %p.text-fg-subtle{ class: "text-[11px]" } no recent activity
- else
  -# Layout knobs lifted from `_hero_subway_map` so the two maps
  -# read at the same visual density.
  - station_spacing = 100
  - pad_x           = 40
  - panel_h         = 72
  - center_y        = 30
  - station_r       = 7
  - focused_r       = 11
  - ring_r          = 15
  - width = pad_x * 2 + station_spacing * [count - 1, 0].max
  - max_w = (width * 1.4).round

  .relative.mx-auto{ data: { controller: "subway-map" },
                     style: "width: 100%; max-width: #{max_w}px;" }
    %svg{ viewBox: "0 0 #{width} #{panel_h}",
          preserveAspectRatio: "xMidYMid meet",
          role: "img",
          "aria-label": "Recent #{count} commits for #{test_case.module}/#{test_case.name}, current outlined",
          class: "block w-full",
          style: "height: auto;" }
      - if count > 1
        %line{ x1: pad_x, y1: center_y,
               x2: pad_x + station_spacing * (count - 1),
               y2: center_y,
               stroke: "var(--color-border-strong)",
               "stroke-width": 2 }
        - (0...count - 1).each do |i|
          - mx = pad_x + station_spacing * (i + 0.5)
          %polygon{ points: "#{mx + 4},#{center_y - 4} #{mx - 5},#{center_y} #{mx + 4},#{center_y + 4}",
                    fill: "var(--color-border-strong)" }

      - window.each_with_index do |commit, i|
        - tcc = tccs_by_commit[commit.id]
        - status = tcc&.status || -1
        - color = "var(--color-#{tcc_status_token(status)})"
        - focused = (commit.sha == focused_sha)
        - r = focused ? focused_r : station_r
        - x = pad_x + station_spacing * i
        - station_title = "#{commit.short_sha} · #{tcc_status_word(status)}"
        %g
          - if focused
            %circle{ cx: x, cy: center_y, r: ring_r,
                     fill: "none",
                     stroke: "var(--color-brand)",
                     "stroke-width": 1.75 }
            %circle{ cx: x, cy: center_y, r: r, fill: color }
            %title= "#{station_title} · current"
          - else
            -# Non-focused stations get the popover hover hooks. The
            -# focused station is the page the user is already on, so
            -# no popover — keeps the visual quiet.
            %a{ href: test_case_commit_path(branch: branch.name,
                                            sha: commit.short_sha,
                                            module: test_case.module,
                                            test_case: test_case.name),
                data: { commit_id: commit.id,
                        action: "mouseenter->subway-map#show mouseleave->subway-map#hide focus->subway-map#show blur->subway-map#hide" } }
              %circle{ cx: x, cy: center_y, r: r, fill: color }
              %title= station_title
          %text{ x: x, y: panel_h - 6,
                 "text-anchor": "middle",
                 "font-family": "var(--font-mono)",
                 "font-size": "10",
                 fill: focused ? "var(--color-fg)" : "var(--color-fg-subtle)" }
            = commit.short_sha

    -# Popover layer. Same percent-of-width positioning as the
    -# commit-show hero subway map so popovers track the stations
    -# as the SVG scales. One popover per non-focused station, hidden
    -# until the matching `data-commit-id` station receives
    -# hover/focus.
    .pointer-events-none.absolute.inset-0
      - window.each_with_index do |commit, i|
        - next if commit.sha == focused_sha
        - tcc = tccs_by_commit[commit.id]
        - status = tcc&.status || -1
        - x_pct = ((pad_x + station_spacing * i).to_f / width * 100).round(2)
        .absolute.z-20.rounded-md.border.border-border.bg-bg-elev.p-2.text-xs{ hidden: true,
            style: "box-shadow: var(--shadow-card-md); width: 240px; left: #{x_pct}%; bottom: 100%; transform: translateX(-50%); margin-bottom: 8px;",
            data: { subway_map_target: "popover", commit_id: commit.id } }
          .flex.items-center.gap-2.mb-1.text-fg
            %span.font-mono.text-brand{ class: "text-[12px]" }= commit.short_sha
            %span.text-fg-subtle ·
            %span.text-fg-subtle.tabular-nums{ class: "text-[11px]" }= time_ago_compact(commit.commit_time)
          .font-medium.text-fg.mb-1.line-clamp-2= commit.message_first_line(80)
          .flex.items-center.gap-2.text-fg-muted{ class: "text-[11px]" }
            = commit_avatar(commit.author, size: 16)
            %span.truncate= commit.author
          .mt-2.flex.items-center.gap-2
            %span{ class: "inline-block h-2 w-2 rounded-full #{tcc_status_dot_class(status)}" }
            %span.text-fg-muted{ class: "text-[11px]" }
              = "#{test_case.module}/#{test_case.name}"
              %span.text-fg-subtle ·
              %span= tcc_status_word(status)
